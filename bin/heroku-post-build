#!/bin/bash
set -e

echo "-----> Starting Heroku build"

# Build Vue frontend
cd frontend

# Generate .env.production from Heroku config vars
cat > .env.production << EOF
VITE_API_URL=${VITE_API_URL}
VITE_FIREBASE_API_KEY=${VITE_FIREBASE_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=${VITE_FIREBASE_AUTH_DOMAIN}
VITE_FIREBASE_PROJECT_ID=${VITE_FIREBASE_PROJECT_ID}
VITE_FIREBASE_STORAGE_BUCKET=${VITE_FIREBASE_STORAGE_BUCKET}
VITE_FIREBASE_MESSAGING_SENDER_ID=${VITE_FIREBASE_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${VITE_FIREBASE_APP_ID}
EOF

echo "-----> Installing frontend dependencies"
npm install

echo "-----> Building Vue frontend"
npm run build

# Copy built files to Laravel public folder
echo "-----> Copying build files to public/"
rm -rf ../public/*
cp -r dist/* ../public/

# Go back to project root
cd ..

# Create storage directories
echo "-----> Creating storage directories"
mkdir -p storage/framework/cache/data
mkdir -p storage/framework/sessions
mkdir -p storage/framework/views
mkdir -p storage/logs

# Copy Firebase credentials (base64 encoded in config)
if [ -n "$FIREBASE_CREDENTIALS_BASE64" ]; then
    echo "-----> Decoding Firebase credentials"
    mkdir -p firebase
    echo "$FIREBASE_CREDENTIALS_BASE64" | base64 -d > firebase/service-account.json
fi

echo "-----> Build complete!"